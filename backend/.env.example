# Groq LLM API token (create at https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Database connection (PostgreSQL). Adjust user/password/db as per your local setup.
# If you prefer MySQL, change the driver accordingly (e.g. mysql+pymysql://...)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aivoa_crm

# App settings
APP_NAME=AIVOA AI-First CRM - HCP Module